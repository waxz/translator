# Backend selection:
# - httpx: direct OpenAI-compatible HTTP calls
# - litellm: provider-aware routing via LiteLLM
BACKEND_TYPE=litellm

# Upstream API configuration
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_BASE_URL=https://integrate.api.nvidia.com/v1

# Optional inbound API key for clients calling this proxy.
# If set, requests must send x-api-key with this exact value.
# If unset, the proxy falls back to permissive local/test key checks.
CLAUDE_API_KEY=sk-ant-test123

# LiteLLM-only provider hint.
# Ignore this for BACKEND_TYPE=httpx.
MODEL_PROVIDER=nvidia_nim
# openai

# Server Configuration
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# Model Configuration
# For NVIDIA NIM + LiteLLM, tool use is usually more reliable with prompt-embedded tools.
DEFAULT_OPENAI_MODEL=meta/llama-4-maverick-17b-128e-instruct
CLAUDE_MODEL_MAP={"claude-3-5-sonnet-20241022":"meta/llama-4-maverick-17b-128e-instruct","claude-3-5-sonnet-20240620":"meta/llama-4-maverick-17b-128e-instruct"}
FORCE_TOOL_IN_PROMPT=true
